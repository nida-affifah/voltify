// src/components/ProductCard.jsx
import React, { useState, useRef, useEffect } from 'react'
import { useNavigate } from 'react-router-dom'

const ProductCard = ({ product, index = 0 }) => {
  const navigate = useNavigate()
  const [adding, setAdding] = useState(false)
  const [isHovered, setIsHovered] = useState(false)
  const [clicked, setClicked] = useState(false)
  const [showToast, setShowToast] = useState(false)
  const [rotateX, setRotateX] = useState(0)
  const [rotateY, setRotateY] = useState(0)
  const cardRef = useRef(null)

  const addToCart = async (e) => {
    e.preventDefault()
    e.stopPropagation()
    
    setClicked(true)
    setTimeout(() => setClicked(false), 300)
    
    const token = localStorage.getItem('token')
    if (!token) {
      if (window.confirm('Silakan login terlebih dahulu')) {
        navigate('/login')
      }
      return
    }
    
    setAdding(true)
    try {
      const res = await fetch('http://localhost:5555/api/cart', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${token}`
        },
        body: JSON.stringify({
          id_produk: product.id_produk,
          jumlah: 1
        })
      })
      const data = await res.json()
      if (data.success) {
        setShowToast(true)
        setTimeout(() => setShowToast(false), 2000)
      } else {
        alert(data.message || 'Gagal menambahkan')
      }
    } catch (error) {
      console.error(error)
      alert('Gagal menambahkan ke keranjang')
    } finally {
      setAdding(false)
    }
  }

  const buyNow = (e) => {
    e.preventDefault()
    e.stopPropagation()
    
    const token = localStorage.getItem('token')
    if (!token) {
      if (window.confirm('Silakan login terlebih dahulu')) {
        navigate('/login')
      }
      return
    }
    navigate(`/checkout?product=${product.id_produk}&quantity=1`)
  }

  // 3D Tilt effect saat mouse bergerak
  const handleMouseMove = (e) => {
    if (!cardRef.current) return
    const rect = cardRef.current.getBoundingClientRect()
    const x = e.clientX - rect.left
    const y = e.clientY - rect.top
    const centerX = rect.width / 2
    const centerY = rect.height / 2
    const rotateXValue = ((y - centerY) / 20) * -1
    const rotateYValue = (x - centerX) / 20
    setRotateX(rotateXValue)
    setRotateY(rotateYValue)
  }

  const handleMouseLeave = () => {
    setRotateX(0)
    setRotateY(0)
    setIsHovered(false)
  }

  const finalPrice = product.harga_diskon || product.harga
  const discount = product.harga_diskon ? 
    Math.round((1 - product.harga_diskon / product.harga) * 100) : 0

  return (
    <>
      {/* Toast Notification dengan efek timbul */}
      {showToast && (
        <div style={{
          position: 'fixed',
          top: '80px',
          right: '20px',
          background: 'linear-gradient(135deg, #4caf50, #45a049)',
          color: 'white',
          padding: '14px 28px',
          borderRadius: '50px',
          zIndex: 9999,
          display: 'flex',
          alignItems: 'center',
          gap: '12px',
          animation: 'slideInRight 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55), fadeOut 0.3s ease 1.7s forwards',
          boxShadow: '0 8px 25px rgba(76, 175, 80, 0.4), 0 0 15px rgba(76, 175, 80, 0.3)',
          fontWeight: 'bold',
          fontSize: '14px'
        }}>
          <span style={{ fontSize: '24px', animation: 'pop 0.3s ease' }}>✅</span>
          <span>Ditambahkan ke keranjang!</span>
        </div>
      )}

      <div
        ref={cardRef}
        onMouseEnter={() => setIsHovered(true)}
        onMouseMove={handleMouseMove}
        onMouseLeave={handleMouseLeave}
        style={{
          background: isHovered ? 'linear-gradient(135deg, #1a1a2e, #1f1f35)' : '#1a1a2e',
          borderRadius: '24px',
          overflow: 'hidden',
          transition: 'all 0.4s cubic-bezier(0.2, 0.9, 0.4, 1.1)',
          border: isHovered ? '1px solid rgba(0, 212, 255, 0.8)' : '1px solid rgba(0,212,255,0.2)',
          position: 'relative',
          transform: isHovered 
            ? `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-15px) scale(1.02)` 
            : 'perspective(1000px) rotateX(0deg) rotateY(0deg) translateY(0) scale(1)',
          boxShadow: isHovered 
            ? '0 30px 50px rgba(0,0,0,0.5), 0 0 30px rgba(0,212,255,0.4), inset 0 1px 1px rgba(255,255,255,0.1)' 
            : '0 15px 30px rgba(0,0,0,0.3)',
          animation: `floatGlow 3s ease-in-out infinite, fadeInUp 0.6s cubic-bezier(0.2, 0.9, 0.4, 1.1) ${index * 0.05}s forwards`,
          opacity: 0,
          transform: 'translateY(40px)'
        }}
      >
        {/* Neon Glow Border Animation */}
        <div style={{
          position: 'absolute',
          top: -2,
          left: -2,
          right: -2,
          bottom: -2,
          background: 'linear-gradient(45deg, #00d4ff, #00ffaa, #ff00ff, #00d4ff)',
          backgroundSize: '400% 400%',
          borderRadius: '26px',
          opacity: isHovered ? 0.4 : 0,
          zIndex: -1,
          transition: 'opacity 0.3s ease',
          animation: 'neonRotate 3s linear infinite',
          filter: 'blur(8px)'
        }} />
        
        {/* Inner Glow */}
        {isHovered && (
          <div style={{
            position: 'absolute',
            inset: 0,
            background: 'radial-gradient(circle at center, rgba(0,212,255,0.1) 0%, transparent 70%)',
            pointerEvents: 'none',
            zIndex: 1
          }} />
        )}
        
        {/* Image container dengan efek timbul */}
        <div style={{
          display: 'flex',
          justifyContent: 'center',
          alignItems: 'center',
          background: 'linear-gradient(135deg, #0a0a12, #12121f)',
          padding: '28px',
          height: '240px',
          position: 'relative',
          overflow: 'hidden'
        }}>
          <img
            src={product.gambar_utama || `https://placehold.co/300x200/0d0d1a/00d4ff?text=${product.nama_produk.substring(0, 10)}`}
            alt={product.nama_produk}
            style={{
              maxWidth: '100%',
              maxHeight: '180px',
              objectFit: 'contain',
              transition: 'transform 0.5s cubic-bezier(0.2, 0.9, 0.4, 1.1), filter 0.3s ease',
              transform: isHovered ? 'scale(1.12) translateY(-5px)' : 'scale(1)',
              filter: isHovered ? 'drop-shadow(0 8px 20px rgba(0,212,255,0.4))' : 'none'
            }}
          />
          
          {/* Floating particle effect on image */}
          {isHovered && (
            <>
              <div style={{
                position: 'absolute',
                top: '20%',
                left: '15%',
                width: '6px',
                height: '6px',
                background: '#00d4ff',
                borderRadius: '50%',
                animation: 'floatParticle 1.5s infinite',
                boxShadow: '0 0 10px #00d4ff'
              }} />
              <div style={{
                position: 'absolute',
                top: '60%',
                right: '20%',
                width: '4px',
                height: '4px',
                background: '#00ffaa',
                borderRadius: '50%',
                animation: 'floatParticle 2s infinite 0.5s',
                boxShadow: '0 0 8px #00ffaa'
              }} />
              <div style={{
                position: 'absolute',
                bottom: '25%',
                left: '25%',
                width: '5px',
                height: '5px',
                background: '#ff00ff',
                borderRadius: '50%',
                animation: 'floatParticle 1.8s infinite 0.3s',
                boxShadow: '0 0 8px #ff00ff'
              }} />
            </>
          )}
          
          {/* Stock badge with pulse */}
          {product.stok < 10 && product.stok > 0 && (
            <div style={{
              position: 'absolute',
              bottom: '16px',
              right: '16px',
              background: 'linear-gradient(135deg, #ff9800, #ff5722)',
              color: 'white',
              padding: '6px 14px',
              borderRadius: '25px',
              fontSize: '11px',
              fontWeight: 'bold',
              animation: 'pulseGlow 1.5s infinite',
              boxShadow: '0 4px 15px rgba(255, 87, 34, 0.4)'
            }}>
              ⚡ Stok Terbatas
            </div>
          )}
        </div>
        
        {/* Discount badge dengan efek timbul */}
        {discount > 0 && (
          <div style={{
            position: 'absolute',
            top: '20px',
            left: '20px',
            background: 'linear-gradient(135deg, #ff6b6b, #ff4757)',
            color: 'white',
            padding: '8px 18px',
            borderRadius: '30px',
            fontSize: '13px',
            fontWeight: 'bold',
            animation: isHovered ? 'bounceGlow 0.6s ease infinite' : 'pulseSoft 2s infinite',
            zIndex: 3,
            boxShadow: '0 5px 15px rgba(255, 71, 87, 0.4)',
            transform: isHovered ? 'scale(1.05)' : 'scale(1)',
            transition: 'transform 0.2s ease'
          }}>
            🔥 HEMAT {discount}%
          </div>
        )}
        
        <div style={{ padding: '20px 20px 24px' }}>
          <h3 style={{
            fontSize: '17px',
            fontWeight: '600',
            marginBottom: '10px',
            color: isHovered ? '#00d4ff' : 'white',
            minHeight: '50px',
            transition: 'all 0.3s ease',
            lineHeight: '1.4',
            textShadow: isHovered ? '0 0 10px rgba(0,212,255,0.5)' : 'none'
          }}>
            {product.nama_produk}
          </h3>
          
          <div style={{ marginBottom: '12px' }}>
            <span style={{
              color: '#00ffaa',
              fontWeight: 'bold',
              fontSize: '22px',
              transition: 'all 0.3s ease',
              display: 'inline-block',
              textShadow: isHovered ? '0 0 8px rgba(0,255,170,0.5)' : 'none'
            }}>
              Rp{Number(finalPrice).toLocaleString('id-ID')}
            </span>
            {product.harga_diskon && (
              <span style={{
                textDecoration: 'line-through',
                color: '#888',
                fontSize: '13px',
                marginLeft: '12px'
              }}>
                Rp{Number(product.harga).toLocaleString('id-ID')}
              </span>
            )}
          </div>
          
          {/* Rating dengan bintang animasi */}
          <div style={{ fontSize: '12px', color: '#888', marginBottom: '14px', display: 'flex', alignItems: 'center', gap: '10px' }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: '3px' }}>
              {[...Array(5)].map((_, i) => (
                <span key={i} style={{
                  color: i < (product.rating_avg || 4) ? '#ffd700' : '#444',
                  fontSize: '12px',
                  animation: isHovered && i < (product.rating_avg || 4) ? 'starPulse 0.3s ease' : 'none',
                  animationDelay: `${i * 0.05}s`
                }}>★</span>
              ))}
            </div>
            <span>{product.rating_avg || '4.5'}</span>
            <span>•</span>
            <span>Terjual {product.total_terjual || 0}</span>
          </div>
          
          <div style={{ fontSize: '11px', color: '#666', marginBottom: '20px', display: 'flex', alignItems: 'center', gap: '8px' }}>
            <span style={{ fontSize: '12px' }}>🏪</span>
            <span>{product.nama_toko}</span>
            {product.is_official && (
              <span style={{ 
                background: 'linear-gradient(135deg, #00d4ff, #00ffaa)',
                color: '#1a1a2e',
                padding: '3px 10px',
                borderRadius: '20px',
                fontSize: '9px',
                fontWeight: 'bold',
                boxShadow: '0 2px 8px rgba(0,212,255,0.3)'
              }}>
                Official Store
              </span>
            )}
          </div>
          
          {/* Buttons dengan efek timbul */}
          <div style={{ display: 'flex', gap: '12px' }}>
            <button
              onClick={addToCart}
              disabled={adding || product.stok <= 0}
              style={{
                flex: 1,
                background: product.stok <= 0 ? '#555' : 
                  clicked ? 'linear-gradient(135deg, #00ffaa, #00d4ff)' : 'linear-gradient(135deg, #00d4ff, #00ffaa)',
                color: product.stok <= 0 ? '#999' : '#1a1a2e',
                border: 'none',
                padding: '13px 8px',
                borderRadius: '14px',
                cursor: product.stok <= 0 ? 'not-allowed' : 'pointer',
                fontWeight: 'bold',
                fontSize: '13px',
                transition: 'all 0.2s ease',
                transform: clicked ? 'scale(0.95)' : isHovered ? 'scale(1.03) translateY(-2px)' : 'scale(1)',
                display: 'flex',
                alignItems: 'center',
                justifyContent: 'center',
                gap: '8px',
                boxShadow: isHovered && !adding && product.stok > 0 ? '0 8px 20px rgba(0,212,255,0.3)' : 'none'
              }}
            >
              {adding ? (
                <>
                  <span className="spinner" style={{
                    display: 'inline-block',
                    width: '14px',
                    height: '14px',
                    border: '2px solid #1a1a2e',
                    borderTopColor: 'transparent',
                    borderRadius: '50%',
                    animation: 'spin 0.6s linear infinite'
                  }} />
                  Menambah...
                </>
              ) : product.stok <= 0 ? '❌ Stok Habis' : '🛒 Tambah ke Keranjang'}
            </button>
            
            {product.stok > 0 && (
              <button
                onClick={buyNow}
                style={{
                  background: 'linear-gradient(135deg, #ff9800, #ff5722)',
                  color: 'white',
                  border: 'none',
                  padding: '13px 24px',
                  borderRadius: '14px',
                  cursor: 'pointer',
                  fontWeight: 'bold',
                  fontSize: '13px',
                  transition: 'all 0.2s ease',
                  transform: isHovered ? 'scale(1.03) translateY(-2px)' : 'scale(1)',
                  display: 'flex',
                  alignItems: 'center',
                  gap: '8px',
                  boxShadow: isHovered ? '0 8px 20px rgba(255, 87, 34, 0.4)' : 'none'
                }}
              >
                💰 Beli Sekarang
              </button>
            )}
          </div>
        </div>
        
        <style>{`
          @keyframes fadeInUp {
            from {
              opacity: 0;
              transform: translateY(40px);
            }
            to {
              opacity: 1;
              transform: translateY(0);
            }
          }
          
          @keyframes floatGlow {
            0%, 100% {
              transform: translateY(0px);
            }
            50% {
              transform: translateY(-5px);
            }
          }
          
          @keyframes neonRotate {
            0% {
              background-position: 0% 50%;
            }
            100% {
              background-position: 100% 50%;
            }
          }
          
          @keyframes bounceGlow {
            0%, 100% {
              transform: scale(1);
              box-shadow: 0 5px 15px rgba(255, 71, 87, 0.4);
            }
            50% {
              transform: scale(1.08);
              box-shadow: 0 8px 25px rgba(255, 71, 87, 0.6);
            }
          }
          
          @keyframes pulseSoft {
            0%, 100% {
              transform: scale(1);
              opacity: 1;
            }
            50% {
              transform: scale(1.02);
              opacity: 0.95;
            }
          }
          
          @keyframes pulseGlow {
            0%, 100% {
              box-shadow: 0 4px 15px rgba(255, 87, 34, 0.4);
              transform: scale(1);
            }
            50% {
              box-shadow: 0 6px 20px rgba(255, 87, 34, 0.7);
              transform: scale(1.02);
            }
          }
          
          @keyframes floatParticle {
            0%, 100% {
              transform: translateY(0px) scale(1);
              opacity: 0.6;
            }
            50% {
              transform: translateY(-15px) scale(1.5);
              opacity: 1;
            }
          }
          
          @keyframes starPulse {
            0%, 100% {
              transform: scale(1);
              text-shadow: 0 0 0px gold;
            }
            50% {
              transform: scale(1.3);
              text-shadow: 0 0 8px gold;
            }
          }
          
          @keyframes shine {
            0% { left: -100%; }
            100% { left: 100%; }
          }
          
          @keyframes slideInRight {
            from {
              transform: translateX(100%);
              opacity: 0;
            }
            to {
              transform: translateX(0);
              opacity: 1;
            }
          }
          
          @keyframes pop {
            0% {
              transform: scale(0);
            }
            80% {
              transform: scale(1.2);
            }
            100% {
              transform: scale(1);
            }
          }
          
          @keyframes fadeOut {
            to {
              opacity: 0;
              visibility: hidden;
            }
          }
          
          @keyframes spin {
            to { transform: rotate(360deg); }
          }
        `}</style>
      </div>
    </>
  )
}

export default ProductCard
